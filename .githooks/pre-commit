#!/usr/bin/env bash
# pre-commit — two safety gates for just-ship repos:
#
#   1. Block edits to installed-copy paths in the self-installed repo
#      (see .claude/rules/self-install-topology.md). Arms only when both
#      ./pipeline/package.json and ./.pipeline/package.json exist.
#
#   2. Reject commits that introduce or modify rule/skill/agent artifacts
#      without an `applies_to:` frontmatter scope marker (T-1021). Arms
#      whenever any framework artifact directory exists in the repo, so it
#      protects both the engine repo and customer installs.

set -euo pipefail

# Emergency override — set this env var to bypass BOTH checks for a single
# commit. Used for the rare case where the installed copy itself legitimately
# needs a manual patch (e.g. resolving a stash-pop mess like T-989) or for
# scripted bulk rewrites of frontmatter where the validation is redundant.
if [ "${GIT_ALLOW_INSTALLED_EDIT:-0}" = "1" ]; then
  exit 0
fi

# Resolve repo root so the hook works regardless of where git was invoked.
REPO_ROOT=$(git rev-parse --show-toplevel)

# ---------------------------------------------------------------------------
# Gate 1 — installed-copy edits (self-install topology, T-988)
# ---------------------------------------------------------------------------
# Self-install signature check — both paths must exist for this gate to arm.
if [ ! -f "$REPO_ROOT/pipeline/package.json" ] || [ ! -f "$REPO_ROOT/.pipeline/package.json" ]; then
  # Skip Gate 1 only — Gate 2 still runs below.
  SKIP_GATE_1=1
fi

# Installed-copy paths. These are written by setup.sh; their source either
# lives at a different path (pipeline/ → .pipeline/) or has no source at all
# (the version/hash stamps). Editing them directly silently diverges the
# install from the framework.
#
# `.claude/{rules,scripts,hooks}/` share the SAME path for source and install,
# so they stay editable with no wrong-copy trap.
#
# `.claude/{agents,commands,skills}/` are ALSO installed copies (source lives
# at `agents/`, `commands/`, `skills/<name>/SKILL.md`), but they are
# intentionally NOT blocked by this hook — the T-989 incident was specifically
# a `.pipeline/` stash-pop. Blocking the other three is deferred to a later
# iteration if the trap bites there too. See .claude/rules/self-install-topology.md
# for the full topology and rationale.
BLOCKED_PREFIXES=(
  ".pipeline/"
  ".claude/.pipeline-version"
  ".claude/.template-hash"
)

# Aggregate exit code — set to 1 by either gate when a violation is found.
# Single exit point at end of file so both gates always run and report.
EXIT=0

if [ "${SKIP_GATE_1:-0}" != "1" ]; then
  # Collect staged files (additions, modifications, renames — NOT deletions,
  # which are the one legitimate edit: removing an obsolete installed file
  # before regenerating with setup.sh).
  #
  # Use `-z` to get NUL-separated raw filenames. The default newline-separated
  # output applies C-style quoting for non-ASCII or special characters (e.g.
  # `.pipeline/weird"name.ts` becomes `".pipeline/weird\"name.ts"`), which
  # would prevent the prefix `case` match from firing — that is a bypass:
  # a file under `.pipeline/` with a quote in its name would slip through.
  # `-z` returns raw bytes with NUL terminators, so the prefix match works
  # unconditionally.
  VIOLATIONS=()
  while IFS= read -r -d '' file; do
    for prefix in "${BLOCKED_PREFIXES[@]}"; do
      case "$file" in
        "$prefix"*)
          VIOLATIONS+=("$file")
          break
          ;;
      esac
    done
  done < <(git diff --cached --name-only --diff-filter=ACMR -z)

  if [ ${#VIOLATIONS[@]} -gt 0 ]; then
    # Walk through each violation with a pointer to the canonical source path.
    # The message names the specific file, not a generic category — a future
    # editor sees exactly what to do.
    {
      echo ""
      echo "✗ Commit blocked — installed-copy paths were modified."
      echo ""
      echo "This repo is Just Ship bootstrapping itself. The paths below are"
      echo "installed copies written by setup.sh. Editing them diverges the"
      echo "installation from the framework source and causes incidents like"
      echo "the T-989 stash-pop conflict."
      echo ""
      echo "Violations:"
      for file in "${VIOLATIONS[@]}"; do
        case "$file" in
          .pipeline/*)
            source_path="${file#.}"
            echo "  ${file}"
            echo "    → edit ${source_path} instead; setup.sh will regenerate ${file}"
            ;;
          .claude/.pipeline-version)
            echo "  ${file}"
            echo "    → this is a version stamp written by setup.sh; do not hand-edit"
            ;;
          .claude/.template-hash)
            echo "  ${file}"
            echo "    → this is a template-hash stamp written by setup.sh; do not hand-edit"
            ;;
          *)
            echo "  ${file}"
            echo "    → installed copy; edit the framework source instead"
            ;;
        esac
      done
      echo ""
      echo "Override (emergency only):"
      echo "  GIT_ALLOW_INSTALLED_EDIT=1 git commit ..."
      echo ""
      echo "See .claude/rules/self-install-topology.md for the full explanation."
    } >&2
    EXIT=1
  fi
fi

# ---------------------------------------------------------------------------
# Gate 2 — applies_to: frontmatter validation (T-1021)
# ---------------------------------------------------------------------------
# Every artifact (rule, skill, agent definition) must carry an `applies_to:`
# scope marker so loaders and human readers can tell where it applies. Without
# the marker, artifacts get loaded into the wrong runtime context and silent
# drift happens (the T-1014 / CTO Audit Lauf 1 / naked-subagent class of bugs).
#
# This gate scans staged additions/modifications under the artifact paths and
# rejects any without `applies_to:` in their frontmatter. Rename-detection is
# enabled (-M) so a pure rename without content change passes; a rename WITH
# modifications is treated as a modification and re-validated.
#
# The vocabulary is loose-validated here (presence of `applies_to:` only) —
# value validation lives in the loader so it can use TypeScript types and
# stays the single source of truth. The hook only catches the missing-field
# case, which is the one that breaks the loader at startup.
#
# Customer projects without source artifact dirs (only .claude/ install dirs)
# still get the `.claude/rules/`, `.claude/skills/`, `.claude/agents/` checks.

ARTIFACT_PATTERNS=(
  ".claude/rules/.*\\.md$"
  ".claude/skills/.*\\.md$"
  ".claude/agents/.*\\.md$"
  "^skills/.*/SKILL\\.md$"
  "^agents/.*\\.md$"
  "^rules/.*\\.md$"
)

MISSING=()
while IFS= read -r -d '' file; do
  matched=0
  for pattern in "${ARTIFACT_PATTERNS[@]}"; do
    if [[ "$file" =~ $pattern ]]; then
      matched=1
      break
    fi
  done
  [ $matched -eq 0 ] && continue

  # Prefer the staged blob (what's about to be committed) over the working tree
  # — that way local edits-since-staging don't fool the check.
  if ! git show ":$file" 2>/dev/null | grep -q "^applies_to:"; then
    MISSING+=("$file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [ ${#MISSING[@]} -gt 0 ]; then
  {
    echo ""
    echo "✗ Commit blocked — artifact files are missing applies_to: frontmatter."
    echo ""
    echo "Every rule, skill, and agent definition must declare its runtime scope so"
    echo "loaders can validate where it applies. Without the marker, artifacts get"
    echo "loaded into the wrong context and silent drift happens (T-1014 class of bugs)."
    echo ""
    echo "Files missing applies_to::"
    for file in "${MISSING[@]}"; do
      echo "  ${file}"
    done
    echo ""
    echo "Fix by adding to the YAML frontmatter at the top of each file:"
    echo "  ---"
    echo "  applies_to: <scope>"
    echo "  # ... other fields"
    echo "  ---"
    echo ""
    echo "Valid scopes: all-agents, top-level-only, subagents-only, audit-runtime-only,"
    echo "             pipeline-runtime-only, engine-repo-only, customer-projects-only,"
    echo "             source-repo-only, install-repo-only, human-readable-only"
    echo ""
    echo "See pipeline/lib/applies-to.ts for the vocabulary and validation logic."
    echo ""
    echo "Override (emergency only):"
    echo "  GIT_ALLOW_INSTALLED_EDIT=1 git commit ..."
  } >&2
  EXIT=1
fi

exit $EXIT
