{
  "name": "just-ship",
  "version": "1.0.0",
  "description": "Autonomous multi-agent development pipeline — from ticket to PR in one command",
  "author": {
    "name": "Just Ship",
    "url": "https://just-ship.io"
  },
  "homepage": "https://just-ship.io",
  "repository": "https://github.com/yves-s/just-ship",
  "license": "MIT",
  "keywords": [
    "autonomous-development",
    "multi-agent",
    "pipeline",
    "ticket-to-pr",
    "claude-code",
    "agents",
    "automation",
    "kanban",
    "devops",
    "ci-cd"
  ],
  "skills": "skills/",
  "agents": "agents/",
  "rules": "rules/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/detect-ticket.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/on-agent-start.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/on-agent-stop.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/on-session-end.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/detect-ticket-post.sh\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/quality-gate.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/quality-gate.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "userConfig": {
    "board_api_key": {
      "description": "Just Ship Board API key (starts with adp_)",
      "sensitive": true
    },
    "board_api_url": {
      "description": "Just Ship Board API base URL (https://board.example.com)",
      "sensitive": false
    },
    "workspace_id": {
      "description": "Just Ship workspace UUID",
      "sensitive": false
    },
    "project_id": {
      "description": "Just Ship project UUID",
      "sensitive": false
    },
    "anthropic_api_key": {
      "description": "Anthropic API key for pipeline runner (VPS only)",
      "sensitive": true
    },
    "github_token": {
      "description": "GitHub personal access token with repo scope (VPS only)",
      "sensitive": true
    }
  }
}
