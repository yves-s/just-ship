{{ 'section-trust-badges.css' | asset_url | stylesheet_tag }}

<div class="trust-badges section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="trust-badges__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="trust-badges__grid trust-badges__grid--{{ section.blocks.size }}-items">
        {%- for block in section.blocks -%}
          <div class="trust-badges__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <div class="trust-badges__icon-wrapper">
                <img
                  src="{{ block.settings.icon | image_url: width: 128 }}"
                  alt="{{ block.settings.label | escape }}"
                  width="{{ block.settings.icon_size }}"
                  height="{{ block.settings.icon_size }}"
                  loading="lazy"
                  class="trust-badges__icon"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.label != blank -%}
              <p class="trust-badges__label">{{ block.settings.label | escape }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .trust-badges__heading {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 2rem;
    margin-top: 0;
  }

  .trust-badges__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 1 auto;
    min-width: 120px;
    max-width: 200px;
  }

  .trust-badges__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .trust-badges__icon {
    display: block;
    object-fit: contain;
  }

  .trust-badges__label {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.4;
    color: rgba(var(--color-foreground), 0.75);
  }

  @media screen and (max-width: 749px) {
    .trust-badges__grid {
      gap: 1.5rem;
    }

    .trust-badges__item {
      min-width: 100px;
      max-width: 160px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Shop With Us"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon size",
          "min": 24,
          "max": 128,
          "step": 4,
          "unit": "px",
          "default": 48
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Trust badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "label": "Free Shipping"
          }
        },
        {
          "type": "badge",
          "settings": {
            "label": "Secure Checkout"
          }
        },
        {
          "type": "badge",
          "settings": {
            "label": "30-Day Returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
