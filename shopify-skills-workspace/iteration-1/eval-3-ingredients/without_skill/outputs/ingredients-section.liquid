{%- comment -%}
  Section: Product Ingredients with Allergen Warnings
  Expects: product.metafields.custom.ingredients (list.metaobject_reference)
  Each metaobject (type: ingredient) has fields: name, description, is_allergen, icon
{%- endcomment -%}

{%- assign ingredients = product.metafields.custom.ingredients.value -%}

{%- if ingredients != blank and ingredients.size > 0 -%}
  <div class="ingredients-section" id="ingredients">
    <h2 class="ingredients-section__title">{{ section.settings.heading }}</h2>

    {%- if section.settings.show_allergen_notice -%}
      {%- assign has_allergens = false -%}
      {%- for ingredient in ingredients -%}
        {%- if ingredient.is_allergen.value == true -%}
          {%- assign has_allergens = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_allergens -%}
        <div class="ingredients-section__allergen-notice" role="alert">
          <svg class="ingredients-section__warning-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          <p>{{ section.settings.allergen_notice_text }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}

    <ul class="ingredients-section__list" role="list">
      {%- for ingredient in ingredients -%}
        {%- assign is_allergen = ingredient.is_allergen.value -%}
        <li class="ingredients-section__item{% if is_allergen %} ingredients-section__item--allergen{% endif %}">
          {%- if ingredient.icon.value != blank -%}
            <div class="ingredients-section__icon">
              <img
                src="{{ ingredient.icon.value | image_url: width: 48 }}"
                alt=""
                width="24"
                height="24"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          <div class="ingredients-section__content">
            <div class="ingredients-section__name-row">
              <span class="ingredients-section__name">{{ ingredient.name.value }}</span>
              {%- if is_allergen -%}
                <span class="ingredients-section__allergen-badge" aria-label="Allergen">
                  {{ section.settings.allergen_badge_text }}
                </span>
              {%- endif -%}
            </div>

            {%- if ingredient.description.value != blank and section.settings.show_descriptions -%}
              <p class="ingredients-section__description">{{ ingredient.description.value }}</p>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product Ingredients",
  "tag": "section",
  "class": "ingredients-wrapper",
  "limit": 1,
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ingredients"
    },
    {
      "type": "checkbox",
      "id": "show_descriptions",
      "label": "Show ingredient descriptions",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_allergen_notice",
      "label": "Show allergen notice banner",
      "default": true
    },
    {
      "type": "text",
      "id": "allergen_notice_text",
      "label": "Allergen notice text",
      "default": "This product contains allergens. Items marked are known allergens."
    },
    {
      "type": "text",
      "id": "allergen_badge_text",
      "label": "Allergen badge text",
      "default": "Allergen"
    }
  ],
  "presets": [
    {
      "name": "Product Ingredients"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  .ingredients-section {
    padding: 2rem 0;
    max-width: 72rem;
    margin: 0 auto;
  }

  .ingredients-section__title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .ingredients-section__allergen-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    background-color: #fef3c7;
    border: 1px solid #f59e0b;
    border-radius: 0.5rem;
    color: #92400e;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .ingredients-section__allergen-notice p {
    margin: 0;
  }

  .ingredients-section__warning-icon {
    flex-shrink: 0;
    color: #d97706;
  }

  .ingredients-section__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .ingredients-section__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background-color: #fff;
    transition: border-color 0.15s ease;
  }

  .ingredients-section__item--allergen {
    border-color: #fbbf24;
    background-color: #fffbeb;
  }

  .ingredients-section__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .ingredients-section__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ingredients-section__content {
    flex: 1;
    min-width: 0;
  }

  .ingredients-section__name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .ingredients-section__name {
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .ingredients-section__allergen-badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background-color: #f59e0b;
    color: #fff;
    line-height: 1.5;
  }

  .ingredients-section__description {
    margin: 0.25rem 0 0;
    font-size: 0.8125rem;
    color: #6b7280;
    line-height: 1.5;
  }

  @media (min-width: 750px) {
    .ingredients-section__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}
