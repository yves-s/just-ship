# Just Ship — Caddy Reverse Proxy Configuration
#
# Domain is set via CADDY_DOMAIN environment variable.
# If not set, Caddy listens on :80 (HTTP only, no TLS).
#
# Required env vars:
#   CADDY_DOMAIN         — e.g. "pipeline.example.com" (enables auto-TLS)
#   MONITORING_USER      — basicauth username for /errors/ and /logs/
#   MONITORING_HASH      — basicauth password hash (generate with: caddy hash-password)

{$CADDY_DOMAIN::80} {
	# ── Security Headers (all responses) ─────────────────────────────────────
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	# ── Monitoring: Bugsink (basicauth) ──────────────────────────────────────
	handle_path /errors/* {
		basic_auth {
			{$MONITORING_USER:admin} {$MONITORING_HASH}
		}
		reverse_proxy bugsink:8000
	}

	# ── Monitoring: Dozzle (basicauth) ───────────────────────────────────────
	handle_path /logs/* {
		basic_auth {
			{$MONITORING_USER:admin} {$MONITORING_HASH}
		}
		reverse_proxy dozzle:8080
	}

	# ── Pipeline API ─────────────────────────────────────────────────────────
	handle {
		reverse_proxy pipeline-server:3001
	}
}
