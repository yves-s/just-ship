# =============================================================================
# agentic-dev-pipeline@.service — systemd Template Unit
#
# Installation:
#   sudo cp agentic-dev-pipeline@.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#
# Starten (ein Service pro Projekt):
#   sudo systemctl enable --now agentic-dev-pipeline@mein-projekt
#
# Voraussetzung:
#   /home/claude-dev/.env              # Globale Keys (ANTHROPIC_API_KEY, GH_TOKEN)
#   /home/claude-dev/.env.mein-projekt # Projekt-spezifische Config
#
# Projekt-Config (.env.{instance}):
#   SUPABASE_URL=https://xxx.supabase.co
#   SUPABASE_SERVICE_KEY=eyJ...
#   SUPABASE_PROJECT_ID=dc2b647e-80cb-4661-8f27-ff811534a0a8
#   PROJECT_DIR=/home/claude-dev/mein-projekt
#   POLL_INTERVAL=60
# =============================================================================

[Unit]
Description=Agentic Dev Pipeline Worker — %i
After=network-online.target
Wants=network-online.target
# Neustart wenn Netzwerk wegbricht
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=claude-dev
Group=claude-dev
WorkingDirectory=/home/claude-dev

# Globale Keys + projektspezifische Overrides
EnvironmentFile=/home/claude-dev/.env
EnvironmentFile=/home/claude-dev/.env.%i

ExecStart=/usr/bin/npx tsx /home/claude-dev/%i/.pipeline/worker.ts

# Logging (zusätzlich zu journald)
StandardOutput=append:/home/claude-dev/pipeline-logs/worker-%i.log
StandardError=append:/home/claude-dev/pipeline-logs/worker-%i.log

# Automatischer Neustart bei Fehler
Restart=on-failure
RestartSec=30s

# Sicherheitseinschränkungen
NoNewPrivileges=true
PrivateTmp=true

# Ressourcen-Limits (Claude Code kann intensiv sein)
LimitNOFILE=65536
MemoryMax=4G
CPUQuota=200%

# Timeout: Pipeline kann lang dauern (Opus + vielen Agents = 30-60 min)
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
